{
  "name": "pjallcate_frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "element-plus": "^2.14.0",
    "nouislider": "^15.8.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.7.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "1.6.17",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.3.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-vue": "^10.9.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9"
  }
}
